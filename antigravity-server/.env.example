# antigravity-server 環境変数設定例
# .env.example をコピーして .env を作成してください（.env は .gitignore 済み）

# ---- サーバー基本設定 ----

# サーバーポート (省略時 3001)
PORT=3001

# 許可するオリジン (PWA の URL)
ALLOWED_ORIGIN=http://localhost:5173

# スナップショットキャッシュの TTL ミリ秒 (省略時 300000 = 5 分)
SNAPSHOT_CACHE_TTL_MS=300000

# ---- Fetcher 選択 ----
# mock    — モック固定値を返す (デフォルト、認証不要)
# jquants — J-Quants API を使用 (下記認証情報が必要)
FETCHER=mock

# ---- J-Quants 認証情報 (FETCHER=jquants の場合に必須) ----
# https://jpx-jquants.com/ でアカウント作成後に設定
#
# [方法A] メール + パスワード認証 (通常アカウント)
# JQUANTS_EMAIL=your@email.com
# JQUANTS_PASSWORD=yourpassword
#
# [方法B] Refresh Token 直接指定 (Google アカウント等、パスワード不使用)
# ダッシュボード → API Keys → Refresh Token をコピーして設定
# ※ refreshToken の有効期限は約1週間。切れたら再取得が必要。
# JQUANTS_REFRESH_TOKEN=your_refresh_token_here
#
# [方法C] API Key 直接指定 (ダッシュボードの API Keys ページで発行)
# Bearer トークンとして API 呼び出しに直接使用
# JQUANTS_API_KEY=your_api_key_here

# ---- Sprint 5-3 以降 (Alpha Vantage / Yahoo Finance) ----
# ALPHA_VANTAGE_API_KEY=your_api_key
